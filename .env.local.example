# Copy to .env.local and fill in to use real data instead of the mock fallback.

# Shopify custom/private app credentials (Admin API, read_orders scope covers abandoned checkouts)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional, defaults to 2024-10
SHOPIFY_API_VERSION=2024-10

# Anthropic API key for the live narration + example-message calls.
# Without this, the app falls back to a hardcoded sentence and message template.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Resend API key — required for the "Check for new cart" live-demo flow to
# send a REAL email. Sign up free at resend.com, create an API key.
# Without this, the live-send button shows a preview instead of delivering.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional. Defaults to a shared Resend testing sender that can send to any
# address without verifying your own domain — fine for a demo.
RESEND_FROM=Cart Recovery Demo <onboarding@resend.dev>
